{:cell/id "link_budget"
 :cell/glyph "烽"
 :cell/face :chip
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/node "gad"
 :cell/doc "Compute the end-to-end optical link power budget + energy-per-bit for a photonicDevice (methods/link_budget.py): laser launch − (modulator IL + grating couplers + waveguide + fibre + connector) vs receiver sensitivity → margin + closes?, plus the CPO energy-per-bit advantage. Emits an opticalLinkBudget Datom. Pure arithmetic over a design — no measured device (G10). R0 scaffold (.solve() raises)."
 :cell/entry "cells/link_budget/cell.py"
 :cell/handler "LinkBudgetCell"
 :cell/state-graph
 {:nodes [:load-device :compute-ledger :margin-check :emit] :entry :load-device
  :edges [[:load-device :compute-ledger] [:compute-ledger :margin-check] [:margin-check :emit] [:emit :end]]}
 :cell/gates ["G9" "G10"]
 :cell/kotoba {:reads [:pdev/id :pdev/line-rate-gbps] :writes [:budget/id :budget/margin-db :budget/closes :budget/energy-pj-bit]}}
